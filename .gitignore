# Unity project .gitignore
# Reviewed and updated: 2026-07-07
# Base: GitHub github/gitignore Unity.gitignore
#
# Place this file at the Unity project root, next to Assets/, Packages/,
# ProjectSettings/, and .git/.

# -----------------------------------------------------------------------------
# Unity-generated folders and caches
# -----------------------------------------------------------------------------
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# Blender backup files imported by Unity are not project source files.
*.blend1
*.blend1.meta

# Memory captures and recordings can be very large and may contain local data.
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Uncomment only when the team intentionally excludes Asset Store Tools.
# /[Aa]ssets/AssetStoreTools*

# Rider-generated Unity plugin and user settings.
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Unity-generated test and cache assets.
InitTestScene*.unity*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
/[Aa]ssets/[Ss]ceneDependencyCache*

# Visual Scripting-generated files.
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# -----------------------------------------------------------------------------
# Addressables generated output
# -----------------------------------------------------------------------------
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
# Example generated state file:
# /Assets/AddressableAssetsData/Windows/addressables_content_state.bin
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# -----------------------------------------------------------------------------
# IDE and editor-generated files
# -----------------------------------------------------------------------------

# Visual Studio
.vs/

# JetBrains Rider / IntelliJ project metadata
.idea/
.fleet/

# Gradle cache
.gradle/

# Generated solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Temporary editor swap/backup files
*.swp
*.swo
*~

# Unity-generated metadata for generated debugger files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# -----------------------------------------------------------------------------
# Operating-system generated files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Crash and diagnostic files
# -----------------------------------------------------------------------------
sysinfo.txt
mono_crash.*

# -----------------------------------------------------------------------------
# Generated build artifacts
# -----------------------------------------------------------------------------
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
crashlytics-build.properties

# -----------------------------------------------------------------------------
# Unity Version Control / Plastic SCM local metadata
# Keep these rules only when this repository uses Git as its sole VCS.
# -----------------------------------------------------------------------------
/.plastic/
/ignore.conf

# -----------------------------------------------------------------------------
# Project-specific rule: external package import area
# -----------------------------------------------------------------------------
# WARNING:
# This is not a universal Unity rule. It is safe only when every teammate imports
# the exact same package version into the exact same path. Scene/Prefab references
# can break when package contents or .meta GUIDs differ between team members.
#
# Recommended alternatives, when possible:
# - Unity Package Manager with Packages/manifest.json and packages-lock.json
# - Commit the imported dependency once, subject to its license and repository size
# - Use a separately versioned embedded/local package
#
/[Aa]ssets/_ExternalPackages/**
